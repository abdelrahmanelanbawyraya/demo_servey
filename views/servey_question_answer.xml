<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="servey_question_answer_list_view" model="ir.ui.view">
        <field name="name">survey.question.answer.list</field>
        <field name="model">survey.question.answer</field>
        <field name="arch" type="xml">
            <list>
                <field name="question_id"/>
                <field name="answer"/>
                <field name="response_id"/>
            </list>
        </field>
    </record>

    <!-- Form View for Survey Question Answer -->
    <record id="servey_question_answer_form_view" model="ir.ui.view">
        <field name="name">survey.question.answer.form</field>
        <field name="model">survey.question.answer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="question_id"/>
                        <field name="answer"/>
                        <field name="response_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Survey Question Answer -->
    <record id="servey_question_answer_action" model="ir.actions.act_window">
        <field name="name">Survey Question Answers</field>
        <field name="res_model">survey.question.answer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>