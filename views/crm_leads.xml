<odoo>
    <record id="view_crm_lead_demo_list" model="ir.ui.view">
        <field name="name">crm.lead.demo.list</field>
        <field name="model">crm.lead.demo</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="car_model"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="phone"/>
                <field name="current_job"/>
                <field name="assign_end_users"  />
            </list>
        </field>
    </record>

    <record id="form_crm_lead_demo" model="ir.ui.view">
        <field name="name">crm.lead.demo.form</field>
        <field name="model">crm.lead.demo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="car_model"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="phone"/>
                        <field name="current_job"/>
                        <field name="assign_end_users"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_lead_demo" model="ir.actions.act_window">
        <field name="name">CRM Leads Demo</field>
        <field name="res_model">crm.lead.demo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>