<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="servey_servey_list_view" model="ir.ui.view">
        <field name="name">survey.survey.list</field>
        <field name="model">survey.survey</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View for Survey Survey -->
    <record id="servey_servey_form_view" model="ir.ui.view">
        <field name="name">survey.survey.form</field>
        <field name="model">survey.survey</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="associated_users" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Questions">
                            <field name="question_ids">
                                <list>
                                    <field name="name"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Survey Survey -->
    <record id="servey_servey_action" model="ir.actions.act_window">
        <field name="name">Surveys</field>
        <field name="res_model">survey.survey</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item for Survey Survey -->
    <!-- <menuitem id="servey_servey_menu" name="Surveys" action="servey_servey_action" parent="your_parent_menu_id" sequence="10"/> -->
</odoo>