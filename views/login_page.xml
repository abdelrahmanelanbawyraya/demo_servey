<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="login_portal" name="Login">
    <xpath expr="//head" position="inside">
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"  crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" /> 
        <t t-call-assets="web.login_style"/> 
        <title>Login</title> 
    </xpath>
    <xpath expr="//body" position="inside">        
        <div class="d-flex" id="login-container">

            <div class="section" id="left">
                <nav class="navbar">
                    <img src="/demo_servey/static/src/img/logo.png" alt="Logo" id="navbar-logo"/>
                </nav>
                <div class="login-container">
                    <form class="login-form" id="login-form" onsubmit="handleSubmit(event)" method="POST" action='/portal/authenticate'>
                        <h2>Login</h2>
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="form-group">
                            <label for="email">Email: </label>
                            <input type="email" id="email" name="email" class="form-control" placeholder="Enter Email ..." required="required"/>
                        </div>
                        <div class="form-group">
                            <label for="password">Password:</label>
                            <input type="password" id="password" name="password" class="form-control" placeholder="Enter password ..." required="required" />
                        </div>
                        <a href="/portal/forget_the_password" id="forget-the-password">Forget the password?</a>
                        <button type="submit" class="btn" id="submitBtn">Login</button>
                        <p style="color:red;text-align: center;" id="error"> <t t-esc="error"/></p>
                    </form>
                </div>
            </div>
            <div class="section" id="right">
                <div id="floating-square">
                    <span id="floating-square-text">Welcome, To RAYA.</span>
                    <img src="/demo_servey/static/src/img/raya_global.png" alt="raya Image"/>
                </div>
            </div>
        </div>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"> </script>  
    </xpath>
    </template>
</odoo>