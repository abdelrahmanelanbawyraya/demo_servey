<odoo>
    <template id="home_portal" name="Home">

        <xpath expr="//head" position="inside">
            <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"  crossorigin="anonymous" />
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" /> 
            <t t-call-assets="web.home_style"/> 
            <title>Login</title> 
        </xpath>

        <xpath expr="//header" position="inside">
            <header id="top" style="background-color: #2145e6 !important; border-bottom: 1px solid #0b5ed7; position: sticky; top: 0; z-index: 1000;">
                <div class="container">
                    <nav class="navbar navbar-expand-lg navbar-dark">
                        <!-- Logo -->
                        <a class="navbar-brand" href="/my">
                            <img src="/demo_servey/static/src/img/logo.png"  
                                    alt="RAYA Logo" style="height: 50px; width: auto;" class="img-fluid"/>
                        </a>

                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                                data-bs-target="#navbarContent" aria-controls="navbarContent"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="navbarContent">
                            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                                <li class="nav-item">
                                    <a class="nav-link active" href="/portal/survey">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/portal/my/surveys">Surveys</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/portal/survey">Profile</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/web/session/logout?redirect=/portal/login">Logout</a>
                                </li>
                            </ul>
                        </div>
                    </nav>
                </div>
            </header>
        </xpath>

        <xpath expr="//body" position="inside">  
            <t t-if="request.params.get('error')">
                <div class="alert alert-danger">
                    <p style="text-align: center;"> 
                        <t t-esc="request.params.get('error')"/>
                    </p>
                </div>
            </t>

            <div class="survey-page">
                <div class="container">
                    <div class="survey-header">
                        <h2>Available Surveys</h2>
                    </div>

                    <t t-if="not surveys">
                        <div class="no-surveys">
                            <i class="fa fa-clipboard-list fa-3x mb-3 text-muted"></i>
                            <h4>No surveys available at the moment</h4>
                            <p>Check back later or contact support if you believe this is an error.</p>
                        </div>
                    </t>

                    <t t-else="">
                        <div class="row g-4">
                            <t t-foreach="surveys" t-as="survey">
                                <div class="col-md-6 col-lg-4">
                                    <div class="survey-card">
                                        <div class="card-body">
                                            <h5 class="survey-title">
                                                <t t-esc="survey.name or 'Untitled Survey'"/>
                                            </h5>
                                            <p class="survey-description">
                                                <t t-esc="survey.description or 'No description provided for this survey.'"/>
                                            </p>
                                            <a t-attf-href="/portal/survey/start/#{survey.id}"
                                            class="start-btn mt-auto">
                                                <i class="fas fa-play-circle"></i>
                                                Start Survey
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </div>

            <div class="oe_structure oe_empty"/>
        </xpath>
    </template>
</odoo>