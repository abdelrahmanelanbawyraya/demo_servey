<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="servey_response_list_view" model="ir.ui.view">
        <field name="name">survey.response.list</field>
        <field name="model">survey.response</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="survey_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <!-- Form View for Survey Response -->
    <record id="servey_response_form_view" model="ir.ui.view">
        <field name="name">survey.response.form</field>
        <field name="model">survey.response</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <field name="state" widget="statusbar" />
                        <field name="sub_state" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <group>
                        <field name="name"/>
                        <field name="survey_id"/>
                        <field name="user_id"/>
                        <field name="lead" />
                    </group>
                    <notebook>
                        <page string="Question Answers">
                            <field name="answer_ids">
                                <list>
                                    <field name="question_id"/>
                                    <field name="answer"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="question_id"/>
                                        <field name="answer"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Comments">
                            <field name="comments" placeholder="Enter your comments here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Survey Response -->
    <record id="servey_response_action" model="ir.actions.act_window">
        <field name="name">Survey Responses</field>
        <field name="res_model">survey.response</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>