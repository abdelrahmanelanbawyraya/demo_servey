<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="question_servey_list_view" model="ir.ui.view">
        <field name="name">survey.question.list</field>
        <field name="model">survey.question</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="survey_id"/>
            </list>
        </field>
    </record>

    <record id="question_servey_form_view" model="ir.ui.view">
        <field name="name">survey.question.form</field>
        <field name="model">survey.question</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="survey_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="question_servey_action" model="ir.actions.act_window">
        <field name="name">Survey Questions</field>
        <field name="res_model">survey.question</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- <menuitem id="question_servey_menu" name="Survey Questions" action="question_servey_action" parent="your_parent_menu_id" sequence="10"/> -->
</odoo>